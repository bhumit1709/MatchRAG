# MatchRAG — Environment Configuration
# Copy this file to .env and adjust values as needed.

# ── Local llama.cpp model ───────────────────────────────────────────────────
# Point this at a local GGUF file.
LLM_MODEL_PATH=models/llama-chat.gguf

# On Apple Silicon, -1 offloads all possible layers to Metal by default.
# Set this explicitly if you want to tune or disable GPU usage.
LLM_N_GPU_LAYERS=-1

# Optional llama.cpp tuning knobs.
LLM_N_CTX=4096
LLM_N_BATCH=256
LLM_MAX_TOKENS=512

# ── Embeddings ──────────────────────────────────────────────────────────────
# Leave unset to use the bundled local BGE model when present.
EMBED_MODEL_PATH=models/bge-small-en-v1.5
EMBED_DEVICE=cpu

# ── Retrieval tuning ────────────────────────────────────────────────────────
# These can materially affect latency.
ENABLE_MULTI_QUERY=true
ENABLE_CONTEXT_COMPRESSION=true
INITIAL_TOP_K=20
TOP_K=8
MULTI_QUERY_COUNT=3

# ── Storage ─────────────────────────────────────────────────────────────────
CHROMA_PATH=chroma_db
COLLECTION_NAME=cricket_commentary

# ── Data ────────────────────────────────────────────────────────────────────
DATA_FILE=data/IndVsNZ.json

# ── API server ──────────────────────────────────────────────────────────────
API_PORT=5001
API_HOST=0.0.0.0

# MatchRAG — Environment Configuration
# Copy this file to .env and adjust values as needed.
# The app works with defaults; only set these to override.

# ── Ollama models ────────────────────────────────────────
# Embedding model (must be pulled via `ollama pull <name>`)
EMBED_MODEL=nomic-embed-text

# LLM model used for answer generation
LLM_MODEL=mistral

# ── Storage ──────────────────────────────────────────────
# Directory where ChromaDB persists the vector index
CHROMA_PATH=chroma_db

# Name of the ChromaDB collection
COLLECTION_NAME=cricket_commentary

# ── Data ─────────────────────────────────────────────────
# Default match JSON file (relative to project root)
DATA_FILE=data/IndVsWI.json

# ── API server ───────────────────────────────────────────
# Port the Flask API listens on
API_PORT=5001

# Host the Flask API binds to (0.0.0.0 = all interfaces)
API_HOST=0.0.0.0
